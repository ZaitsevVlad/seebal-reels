{
"update_url": "https://clients2.google.com/service/update2/crx",

  "name": "vidIQ Vision for YouTube",
  "version": "3.199.0",
  "description": "Uncover the secrets to success behind your favorite YouTube videos.",
  "manifest_version": 3,
  "default_locale": "en",
  "homepage_url": "https://vidiq.com/",
  "options_page": "options.html",
  "icons": {
    "48": "images/vidiq-badge.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "oauth2": {
    "client_id": "928183395842-ig3govj9ifu752sb956mp3kbecivb8a3.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "profile",
      "email"
    ]
  },
  "permissions": [
    "cookies",
    "clipboardWrite",
    "storage",
    "background",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://studio.youtube.com/*"
      ],
      "exclude_matches": [
        "*://www.youtube.com/subscribe_embed*"
      ],
      "css": [
        "bundle.css"
      ],
      "js": [
        "bundle.bundle.js"
      ]
    },
    {
      "matches": [
        "*://www.tiktok.com/*"
      ],
      "js": [
        "tiktok.bundle.js"
      ]
    },
    {
      "matches": [
        "*://www.tiktok.com/*"
      ],
      "js": [
        "tiktokDocumentStart.bundle.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://www.instagram.com/*"
      ],
      "css": [
        "instagram.css"
      ],
      "js": [
        "instagram.bundle.js"
      ]
    },
    {
      "matches": [
        "*://claude.ai/*"
      ],
      "js": [
        "claude.bundle.js"
      ]
    },
    {
      "matches": [
        "*://chatgpt.com/*"
      ],
      "js": [
        "chatgptAuthBridge.bundle.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://chatgpt.com/*"
      ],
      "css": [
        "chatgpt.css"
      ],
      "js": [
        "chatgpt.bundle.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://gemini.google.com/*"
      ],
      "js": [
        "gemini.bundle.js"
      ]
    },
    {
      "matches": [
        "*://www.youtube.com/embed/*"
      ],
      "all_frames": true,
      "js": [
        "getIframeVideoStill.bundle.js"
      ]
    },
    {
      "matches": [
        "*://app.vidiq.com/*",
        "*://vidiq.com/*"
      ],
      "run_at": "document_idle",
      "js": [
        "extensionLogin.bundle.js",
        "webappMessaging.bundle.js"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "*://studio.youtube.com/*"
      ],
      "all_frames": true,
      "js": [
        "fetchDOMContent.bundle.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.bundle.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "bridge.html",
