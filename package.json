{
  "name": "seebal-reels",
  "version": "1.0.0",
  "description": "SEEBAL Instagram Reels Downloader",
  "author": "SEEBAL",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac --universal",
    "dist:all": "electron-builder --win --mac --x64"
  },
  "build": {
    "appId": "com.seebal.reels",
    "productName": "SEEBAL Reels",
    "copyright": "Copyright © 2026 SEEBAL",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.social-networking",
      "darkModeSupport": true,
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "portable": {
      "artifactName": "SEEBAL-Reels-Windows.exe"
    },
    "mac": {
      "artifactName": "SEEBAL-Reels-Mac-${arch}.zip"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
