{
  "name": "ssibalreels-beta",
  "version": "1.23.0",
  "description": "ssibalreels(beta) Instagram Reels Downloader",
  "author": "ssibalhub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64 --publish never",
    "dist:mac": "electron-builder --mac --universal --publish never"
  },
  "build": {
    "appId": "com.ssibal.reels",
    "productName": "ssibalreels(beta)",
    "asar": false,
    "copyright": "Copyright В© 2026 SEEBAL",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**/*",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "ssibalreels-beta-Windows.exe"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.social-networking",
      "darkModeSupport": true,
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "icon": "build/icon.icns",
      "artifactName": "ssibalreels-beta-Mac.zip"
    },
    "portable": {
      "artifactName": "ssibalreels-beta-Windows.exe"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}

